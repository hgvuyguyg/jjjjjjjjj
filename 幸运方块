local lucky_collectToggle = false
local lucky_collectRunning = false
local function lucky_collectLoop()
    lucky_collectRunning = true
    while lucky_collectRunning and lucky_collectToggle do
        for i = 1, 10 do
            if not lucky_collectToggle then break end
            pcall(function()
                game:GetService("ReplicatedStorage"):WaitForChild("Shared"):WaitForChild("Packages"):WaitForChild("Network"):WaitForChild("rev_B_Collect"):FireServer(i)
            end)
        end
        task.wait(0)
    end
    lucky_collectRunning = false
end
lucky_Btn2.MouseButton1Click:Connect(function()
    lucky_collectToggle = not lucky_collectToggle
    if lucky_collectToggle then
        lucky_Btn2.BackgroundColor3 = Color3.fromRGB(76, 175, 80)
        lucky_Btn2.Text = "停止"
        if not lucky_collectRunning then
            task.spawn(lucky_collectLoop)
        end
    else
        lucky_Btn2.BackgroundColor3 = Color3.fromRGB(255, 140, 0)
        lucky_Btn2.Text = "执行"
    end
end)
lucky_Btn2.MouseEnter:Connect(function()
    if not lucky_collectToggle then lucky_Btn2.BackgroundColor3 = Color3.fromRGB(255, 160, 20) end
end)
lucky_Btn2.MouseLeave:Connect(function()
    if not lucky_collectToggle then lucky_Btn2.BackgroundColor3 = Color3.fromRGB(255, 140, 0) end
end)

