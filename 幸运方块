local lucky_isOpen = false
local function lucky_openPanel()
    lucky_isOpen = true
    lucky_MainFrame.Size = UDim2.new(0, 0, 0, 0); lucky_MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    lucky_MainFrame.Visible = true
    TweenService:Create(lucky_MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 580, 0, 440), Position = UDim2.new(0.5, -290, 0.5, -220)}):Play()
end
local function lucky_closePanel()
    lucky_isOpen = false
    TweenService:Create(lucky_MainFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
    wait(0.15); lucky_MainFrame.Visible = false
end
lucky_OpenBtn.MouseButton1Click:Connect(function()
    if lucky_isOpen then lucky_closePanel() else lucky_openPanel() end
end)
