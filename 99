function forestPullItems()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart

    local counts = {
        log = 0, coal = 0, oil = 0, bandage = 0,
        carrot = 0, berry = 0, cake = 0,
        iron = 0, microwave = 0, screw = 0,
        fan = 0, tire = 0
    }
    local allItems = {}
    local processed = {}

    for _, obj in ipairs(workspace:GetDescendants()) do
        if forestPullLog and obj.Name == "Log" and obj:IsA("BasePart") then
            if not processed[obj] and not forestIsExcluded(obj) then
                table.insert(allItems, obj)
                processed[obj] = true
                counts.log = counts.log + 1
            end
        end

        if forestPullCoal and obj.Name == "Coal" and obj:IsA("BasePart") then
            if not processed[obj] and not forestIsExcluded(obj) then
                table.insert(allItems, obj)
                processed[obj] = true
                counts.coal = counts.coal + 1
            end
        end

        if obj:IsA("BasePart") then
            local parent = obj.Parent
            if parent and parent:IsA("Model") and not processed[parent] and not forestIsExcluded(parent) then
                if parent:FindFirstChild("Humanoid") then continue end

                local hasCap = parent:FindFirstChild("Cap")
                local hasMain = parent:FindFirstChild("Main")
                local hasTie = parent:FindFirstChild("Tie")
                local hasHandle = parent:FindFirstChild("Handle")
                local hasPart = parent:FindFirstChild("Part")
                local hasLeaf = parent:FindFirstChild("Leaf")
                local hasAttachPoint = parent:FindFirstChild("AttachPoint")
                local hasBack = parent:FindFirstChild("Back")
                local hasBase = parent:FindFirstChild("Base")
                local hasGlass = parent:FindFirstChild("Glass")
                local hasStand = parent:FindFirstChild("Stand")
                local hasHead = parent:FindFirstChild("Head")
                local hasMiddle = parent:FindFirstChild("Middle")
                local hasFans = parent:FindFirstChild("Fans")
                local hasRim = parent:FindFirstChild("Rim")
                local hasCenter = parent:FindFirstChild("Center")

                -- 油桶
                if forestPullOil and hasCap and hasMain and forestIsOilBarrel(parent) then
                    table.insert(allItems, parent)
                    processed[parent] = true
                    counts.oil = counts.oil + 1
                end

                -- 绷带
                if forestPullBandage and hasTie and hasHandle then
                    table.insert(allItems, parent)
                    processed[parent] = true
                    counts.bandage = counts.bandage + 1
                end

                -- 胡萝卜
                if forestPullCarrot and hasPart and hasLeaf and hasHandle and not hasCap and not hasMain and not hasTie then
                    table.insert(allItems, parent)
                    processed[parent] = true
                    counts.carrot = counts.carrot + 1
                end

                -- 浆果
                if forestPullBerry and hasPart and hasHandle and not hasLeaf and not hasCap and not hasMain and not hasTie then
                    local isWorkbench = false
                    for _, name in ipairs(forestExcludedNames) do
                        if string.find(parent.Name, name) then isWorkbench = true; break end
                    end
                    if not isWorkbench then
                        table.insert(allItems, parent)
                        processed[parent] = true
                        counts.berry = counts.berry + 1
                    end
                end

                -- 蛋糕
                if forestPullCake and hasHandle and not hasCap and not hasMain and not hasTie and not hasPart and not hasLeaf then
                    local childCount = 0
                    for _, child in pairs(parent:GetChildren()) do
                        if child:IsA("BasePart") then childCount = childCount + 1 end
                    end
                    if childCount == 1 then
                        table.insert(allItems, parent)
                        processed[parent] = true
                        counts.cake = counts.cake + 1
                    end
                end

                -- 铁板
                if forestPullIron and hasMain and not hasCap and not hasTie and not hasHandle and not hasPart and not hasLeaf and forestIsIronPlate(parent) then
                    if counts.iron < 8 then
                        table.insert(allItems, parent)
                        processed[parent] = true
                        counts.iron = counts.iron + 1
                    end
                end

                -- 微波炉
                if forestPullMicrowave and hasPart and hasMain and hasBack and hasBase and hasGlass and hasAttachPoint then
                    table.insert(allItems, parent)
                    processed[parent] = true
                    counts.microwave = counts.microwave + 1
                end

                -- 螺丝钉
                if forestPullScrew and hasMain and not hasCap and not hasTie and not hasHandle and not hasPart and not hasLeaf and forestIsScrew(parent) then
                    if counts.screw < 8 then
                        table.insert(allItems, parent)
                        processed[parent] = true
                        counts.screw = counts.screw + 1
                    end
                end

                -- 风扇
                if forestPullFan and hasStand and hasMain and hasHead and hasMiddle and hasFans then
                    table.insert(allItems, parent)
                    processed[parent] = true
                    counts.fan = counts.fan + 1
                end

                -- 新轮胎
                if forestPullTire and hasRim and hasCenter and hasMain and hasPart then
                    table.insert(allItems, parent)
                    processed[parent] = true
                    counts.tire = counts.tire + 1
                end
            end
        end
    end

    local total = #allItems
    if total > 0 then
        local radius = 3.5
        local angleStep = (2 * math.pi) / total
        local groundY = hrp.Position.Y - 1.0

        for i, obj in ipairs(allItems) do
            local angle = i * angleStep + os.clock() * 0.2
            local xOffset = math.cos(angle) * radius
            local zOffset = math.sin(angle) * radius
            local targetPos = Vector3.new(hrp.Position.X + xOffset, groundY, hrp.Position.Z + zOffset)

            if obj:IsA("Model") then
                obj:MoveTo(targetPos)
            elseif obj:IsA("BasePart") then
                obj.CFrame = CFrame.new(targetPos)
            end
        end
    end

    local totalCount = counts.log + counts.coal + counts.oil + counts.bandage + counts.carrot + counts.berry + counts.cake + counts.iron + counts.microwave + counts.screw + counts.fan + counts.tire
    if totalCount > 0 then
        forestStatusLabel.Text = "已吸 " .. totalCount .. " 件 | 🪵"..counts.log.." 🪨"..counts.coal.." 🛢️"..counts.oil.." 🩹"..counts.bandage.." 🥕"..counts.carrot.." 🫐"..counts.berry.." 🍰"..counts.cake.." 🔩"..counts.iron.." 📺"..counts.microwave.." 🔧"..counts.screw.." 🌀"..counts.fan.." 🛞"..counts.tire
    else
        forestStatusLabel.Text = "状态: 等待中..."
    end
end

