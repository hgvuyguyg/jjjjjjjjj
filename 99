end

local function forestSelectNav(button, itemName)
    if forestSelectedNav then forestSelectedNav.BackgroundColor3 = Color3.fromRGB(255, 255, 255) end
    button.BackgroundColor3 = Color3.fromRGB(230, 230, 230)
    forestSelectedNav = button
    forestTitleLabel.Text = itemName
    forestSwitchContent(itemName)
end

