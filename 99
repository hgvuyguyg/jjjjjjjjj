local enabled = false
local pullLog = false
local pullCoal = false
local pullOil = false
local pullBandage = false
local pullCarrot = false
local pullBerry = false
local pullCake = false

local excludedNames = {"Workbench", "工作台", "Table", "Crafting"}

function isExcluded(obj)
    for _, name in ipairs(excludedNames) do
        if string.find(obj.Name, name) then return true end
        local parent = obj.Parent
        if parent and string.find(parent.Name, name) then return true end
    end
    return false
end

function pullItems()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    
    local allItems = {}
    local processed = {}
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if pullLog and obj.Name == "Log" and obj:IsA("BasePart") then
            if not processed[obj] and not isExcluded(obj) then
                table.insert(allItems, obj)
                processed[obj] = true
            end
        end
        
        if pullCoal and obj.Name == "Coal" and obj:IsA("BasePart") then
            if not processed[obj] and not isExcluded(obj) then
                table.insert(allItems, obj)
                processed[obj] = true
            end
        end
        
        if obj:IsA("BasePart") then
            local parent = obj.Parent
            if parent and parent:IsA("Model") and not processed[parent] and not isExcluded(parent) then
                if parent:FindFirstChild("Humanoid") then continue end
                
                local hasCap = parent:FindFirstChild("Cap")
                local hasMain = parent:FindFirstChild("Main")
                local hasTie = parent:FindFirstChild("Tie")
                local hasHandle = parent:FindFirstChild("Handle")
                local hasPart = parent:FindFirstChild("Part")
                local hasLeaf = parent:FindFirstChild("Leaf")
                
                if pullOil and hasCap and hasMain then
                    table.insert(allItems, parent)
                    processed[parent] = true
                elseif pullBandage and hasTie and hasHandle then
                    table.insert(allItems, parent)
                    processed[parent] = true
                elseif pullCarrot and hasPart and hasLeaf and hasHandle and not hasCap and not hasMain and not hasTie then
                    table.insert(allItems, parent)
                    processed[parent] = true
                elseif pullBerry and hasPart and hasHandle and not hasLeaf and not hasCap and not hasMain and not hasTie then
                    local isWorkbench = false
                    for _, name in ipairs(excludedNames) do
                        if string.find(parent.Name, name) then isWorkbench = true; break end
                    end
                    if not isWorkbench then
                        table.insert(allItems, parent)
                        processed[parent] = true
                    end
                elseif pullCake and hasHandle and not hasCap and not hasMain and not hasTie and not hasPart and not hasLeaf then
                    local childCount = 0
                    for _, child in pairs(parent:GetChildren()) do
                        if child:IsA("BasePart") then childCount = childCount + 1 end
                    end
                    if childCount == 1 then
                        table.insert(allItems, parent)
                        processed[parent] = true
                    end
                end
            end
        end
    end
    
    local total = #allItems
    if total > 0 then
        local radius = 3.5
        local angleStep = (2 * math.pi) / total
        local groundY = hrp.Position.Y - 1.0
        
        for i, obj in ipairs(allItems) do
            local angle = i * angleStep + os.clock() * 0.2
            local xOffset = math.cos(angle) * radius
            local zOffset = math.sin(angle) * radius
            local targetPos = Vector3.new(hrp.Position.X + xOffset, groundY, hrp.Position.Z + zOffset)
            
            if obj:IsA("Model") then
                obj:MoveTo(targetPos)
            elseif obj:IsA("BasePart") then
                obj.CFrame = CFrame.new(targetPos)
            end
        end
    end
end

spawn(function()
    while ScreenGui and ScreenGui.Parent do
        if enabled then pullItems() end
        task.wait(0.8)
    end
end)

