    doors_smallAlertText.Text = "⚠ " .. name .. " " .. string.format("%.1f", dist) .. "m"
    doors_smallAlertTween = TweenService:Create(doors_smallAlertFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(1, -10, 0.1, 0)})
    doors_smallAlertTween:Play()
    task.delay(3, function()
        pcall(function()
            doors_smallAlertTween = TweenService:Create(doors_smallAlertFrame, TweenInfo.new(0.3), {Position = UDim2.new(1, 230, 0.1, 0)})
            doors_smallAlertTween:Play(); task.wait(0.3); doors_smallAlertFrame.Visible = false; doors_smallAlertActive = false; doors_smallAlertActiveMonster = nil
        end)
    end)
end

local doors_monsterInRange = {}

function doors_checkMonsters()
    if not doors_monsterAlertEnabled then return end
    local ch = LocalPlayer.Character
    if not ch or not ch:FindFirstChild("HumanoidRootPart") then return end
    local hrp = ch.HumanoidRootPart
    local currentlyInRange = {}
    for _, o in ipairs(workspace:GetDescendants()) do
        if o:IsA("Model") and not Players:GetPlayerFromCharacter(o) then
            local mn = doors_getMonsterName(o)
            if mn then
                local po = o:FindFirstChildWhichIsA("BasePart")
                if po then
                    local d = (po.Position - hrp.Position).Magnitude
                    local md = (mn == "Rush" or mn == "Ambush") and 500 or (mn == "Seek") and 300 or (mn == "Screech") and 40 or 80
                    if d < md then
                        currentlyInRange[mn] = true
                        if not doors_monsterInRange[mn] then
                            doors_monsterInRange[mn] = true
                            if mn == "Rush" or mn == "Ambush" then doors_showBanner(mn, d) else doors_showSmallAlert(mn, d) end
                        end
                    end
                end
            end
        end
    end
    for mn, _ in pairs(doors_monsterInRange) do
        if not currentlyInRange[mn] then
            doors_monsterInRange[mn] = nil
            if mn == "Rush" or mn == "Ambush" then doors_bannerActive = false; doors_bannerActiveMonster = nil
            else doors_smallAlertActive = false; doors_smallAlertActiveMonster = nil end
        end
    end
end

spawn(function() while true do doors_checkMonsters(); task.wait(1) end end)
