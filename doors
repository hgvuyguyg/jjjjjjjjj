                local s = ...
                if rawequal(s, E) and getnamecallmethod() == "FireServer" then
                    local A = table.pack(...)
                    local R = table.pack(m(s, table.unpack(A, 1, A.n)))
                    return table.unpack(R, 1, R.n)
                end
                return m(...)
            end)
            local o
            o = hookfunction(E.FireServer, function(...)
                local s = ...
                if rawequal(s, E) then
                    local A = table.pack(...)
                    local R = table.pack(o(table.unpack(A, 1, A.n)))
                    return table.unpack(R, 1, R.n)
                end
                return o(s, ...)
            end)
        end
    end
})

