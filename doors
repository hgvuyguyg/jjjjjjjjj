function showPopup(name)
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return
    end
    
    while #activePopups >= 5 do 
        local old = table.remove(activePopups,1)
        if old then old:Destroy() end
    end
    
    for _,p in ipairs(activePopups) do
        TweenService:Create(p,TweenInfo.new(0.25),{Position=UDim2.new(0,0,0,p.Position.Y.Offset+72)}):Play()
    end
    
    local popup = Instance.new("Frame")
    popup.Size = UDim2.new(0,280,0,60)
    popup.Position = UDim2.new(0,-300,0,0)
    popup.BackgroundColor3 = Color3.fromRGB(200,50,50)
    popup.BorderSizePixel = 2
    popup.BorderColor3 = Color3.fromRGB(255,0,0)
    popup.ZIndex = 9999
    popup.Parent = popupContainer
    
    local icon = Instance.new("TextLabel")
    icon.Size = UDim2.new(0,40,0,40)
    icon.Position = UDim2.new(0,8,0,10)
    icon.BackgroundTransparency = 1
    icon.Text = "⚠"
    icon.Font = Enum.Font.SourceSansBold
    icon.TextSize = 28
    icon.ZIndex = 9999
    icon.Parent = popup
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1,-60,0,28)
    title.Position = UDim2.new(0,50,0,5)
    title.BackgroundTransparency = 1
    title.TextColor3 = Color3.new(1,1,1)
    title.Text = name.." 来了！"
    title.Font = Enum.Font.SourceSansBold
    title.TextSize = 16
    title.ZIndex = 9999
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = popup
    
    local desc = Instance.new("TextLabel")
    desc.Size = UDim2.new(1,-60,0,22)
    desc.Position = UDim2.new(0,50,0,33)
    desc.BackgroundTransparency = 1
    desc.TextColor3 = Color3.fromRGB(255,200,200)
    desc.Text = "🏃 找个地方躲起来！"
    desc.Font = Enum.Font.SourceSans
    desc.TextSize = 12
    desc.ZIndex = 9999
    desc.TextXAlignment = Enum.TextXAlignment.Left
    desc.Parent = popup
    
    table.insert(activePopups,popup)
    TweenService:Create(popup,TweenInfo.new(0.4,Enum.EasingStyle.Quad),{Position=UDim2.new(0,0,0,0)}):Play()
    
    pcall(function()
        local sound = Instance.new("Sound",popup)
        sound.SoundId = "rbxassetid://147722335"
        sound.Volume = 1.5
        sound:Play()
    end)
    
    task.delay(5,function()
        pcall(function()
            TweenService:Create(popup,TweenInfo.new(0.4),{Position=UDim2.new(0,-300,0,popup.Position.Y.Offset)}):Play()
            task.wait(0.4)
            for i,p in ipairs(activePopups)do 
                if p==popup then 
                    table.remove(activePopups,i)
                    break 
                end 
            end
            popup:Destroy()
            for _,p in ipairs(activePopups)do
                TweenService:Create(p,TweenInfo.new(0.25),{Position=UDim2.new(0,0,0,p.Position.Y.Offset-72)}):Play()
            end
        end)
    end)
end

