function showBanner(name,dist)
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return
    end
    
    table.insert(bannerQueue,{name=name,dist=dist})
    if bannerActive then return end
    bannerActive = true
    while #bannerQueue > 0 do
        local data = table.remove(bannerQueue,1)
        bannerFrame.Visible = true
        bannerText.Text = "⚠ "..data.name.." 来了！ "..string.format("%.0f",data.dist).."m | 快躲起来！ ⚠"
        pcall(function()
            local s = Instance.new("Sound",bannerFrame)
            s.SoundId = "rbxassetid://9126074485"
            s.Volume = 2
            s:Play()
        end)
        task.wait(6)
        bannerFrame.Visible = false
    end
    bannerActive = false
end

