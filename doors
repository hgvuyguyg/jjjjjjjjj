    local D = Instance.new("TextLabel"); D.Size = UDim2.new(1, -100, 0, 13); D.Position = UDim2.new(0, 44, 0, 22); D.Text = desc; D.TextColor3 = Color3.fromRGB(130, 130, 130); D.Font = Enum.Font.Gotham; D.TextSize = 9; D.BackgroundTransparency = 1; D.TextXAlignment = Enum.TextXAlignment.Left; D.ZIndex = 8; D.Parent = C
    local B = Instance.new("TextButton"); B.Size = UDim2.new(0, 50, 0, 20); B.Position = UDim2.new(1, -58, 0, 13); B.Text = btnText or "执行"; B.TextColor3 = Color3.fromRGB(255, 255, 255); B.Font = Enum.Font.GothamBold; B.TextSize = 10; B.BackgroundColor3 = Color3.fromRGB(255, 140, 0); B.BorderSizePixel = 0; B.ZIndex = 9; B.AutoButtonColor = false; B.Parent = C
    Instance.new("UICorner", B).CornerRadius = UDim.new(0, 5)
