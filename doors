doors_createCard(doors_mainPage, "防滑模式", "松开按键刹停0.15秒", "🧊", function(s)
    doors_antiSlipEnabled = s
    if s then
        local brakeTime = 0
        local cn = RunService.RenderStepped:Connect(function()
            if not doors_antiSlipEnabled then return end
            pcall(function()
                local p = LocalPlayer.Character
                if p and p:FindFirstChild("HumanoidRootPart") and p:FindFirstChild("Humanoid") then
                    local hum = p.Humanoid; local hrp = p.HumanoidRootPart
                    if hum.MoveDirection.Magnitude == 0 then
                        if brakeTime == 0 then brakeTime = tick() end
                        if tick() - brakeTime < 0.15 then hrp.Velocity = Vector3.new(0, hrp.Velocity.Y, 0) end
                    else brakeTime = 0 end
                end
            end)
        end)
        return cn
    end
end, "开启")

doors_createCard(doors_mainPage, "自动互动", "附近有画不互动，Door长按E", "🤖", function(s)
    doors_autoInteractEnabled = s
    if s then
        local lastInteract = 0
        local cn = RunService.RenderStepped:Connect(function()
            if not doors_autoInteractEnabled then return end
            local now = tick(); if now - lastInteract < 0.2 then return end; lastInteract = now
            pcall(function()
                local p = LocalPlayer.Character
                if not p or not p:FindFirstChild("HumanoidRootPart") then return end
                local hrp = p.HumanoidRootPart
                local nearPainting = false
                for _, o in ipairs(workspace:GetDescendants()) do
                    if o.Name:lower():find("painting") or o.Name:lower():find("画") then
                        local po = doors_getPos(o)
                        if po and (po - hrp.Position).Magnitude < 10 then nearPainting = true; break end
                    end
                end
                if nearPainting then return end
                for _, o in ipairs(workspace:GetDescendants()) do
                    if o:IsA("ProximityPrompt") and o.Enabled then
                        local pp = o.Parent
                        if pp then
                            local po = nil
                            if pp:IsA("BasePart") then po = pp.Position
                            elseif pp:IsA("Model") then local bp = pp:FindFirstChildWhichIsA("BasePart"); if bp then po = bp.Position end end
                            if po and (po - hrp.Position).Magnitude < 10 then
                                local pn = pp.Name:lower()
                                if pn == "door" or (pp.Parent and pp.Parent.Name:lower() == "door") then fireproximityprompt(o, 1)
                                elseif not doors_allowCabinets then
                                    local cabinetNames = {"wardrobe", "cabinet", "closet", "bed", "衣柜", "柜子", "床", "hide", "hiding"}
                                    local isCabinet = false
                                    for _, kw in ipairs(cabinetNames) do if pn:find(kw) then isCabinet = true; break end end
                                    if not isCabinet then fireproximityprompt(o) end
                                else fireproximityprompt(o) end
                                break
                            end
                        end
                    end
                end
            end)
        end)
        return cn
    end
end, "开启")

