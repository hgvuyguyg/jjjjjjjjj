            local mtHook
            mtHook = hookmetamethod(game, "__namecall", function(...)
                local self = ...
                if rawequal(self, Event) and getnamecallmethod() == "FireServer" then
                    local Args = table.pack(...)
                    local Result = table.pack(mtHook(self, table.unpack(Args, 1, Args.n)))
                    return table.unpack(Result, 1, Result.n)
                end
                return mtHook(...)
            end)
            local OldFireServer
            OldFireServer = hookfunction(Event.FireServer, function(...)
                local self = ...
                if rawequal(self, Event) then
                    local Args = table.pack(...)
                    local Result = table.pack(OldFireServer(table.unpack(Args, 1, Args.n)))
                    return table.unpack(Result, 1, Result.n)
                end
                return OldFireServer(self, ...)
            end)
        end
    end
})

