function clearAll()
    for _, d in pairs(highlights) do pcall(function() if d.hl then d.hl:Destroy() end if d.bb then d.bb:Destroy() end if d.conn then d.conn:Disconnect() end end) end
    highlights = {}; clearBeams()
end

function clearBeams()
    for _, b in pairs(beamData) do pcall(function() if b.beam then b.beam:Destroy() end if b.a0 then b.a0:Destroy() end if b.a1 then b.a1:Destroy() end if b.label then b.label:Destroy() end end) end
    beamData = {}
end

function getPos(obj)
    if obj:IsA("BasePart") then return obj.Position end
    if obj:IsA("Model") then local p=obj:FindFirstChildWhichIsA("BasePart");if p then return p.Position end end
    return nil
end

function addESP(obj, color, name)
    pcall(function()
        local hl = Instance.new("Highlight");hl.FillColor=color;hl.FillTransparency=0.3;hl.OutlineColor=Color3.fromRGB(255,255,255);hl.OutlineTransparency=0;hl.Adornee=obj;hl.Parent=obj;hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
        local bb = Instance.new("BillboardGui");bb.Size=UDim2.new(0,200,0,30);bb.AlwaysOnTop=true;bb.Parent=obj
        local lb = Instance.new("TextLabel");lb.Size=UDim2.new(1,0,1,0);lb.BackgroundTransparency=1;lb.TextColor3=Color3.fromRGB(255,255,255);lb.Font=Enum.Font.SourceSansBold;lb.TextSize=16;lb.Parent=bb
        local conn = RunService.Heartbeat:Connect(function()
            if not obj or not obj.Parent then conn:Disconnect();hl:Destroy();bb:Destroy();return end
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then local pos=getPos(obj);if pos then lb.Text=string.format("%s %.1fm",name,(char.HumanoidRootPart.Position-pos).Magnitude) end end
        end)
        table.insert(highlights,{hl=hl,bb=bb,conn=conn})
    end)
end

function addScreenBeam(targetObj, color, name)
    pcall(function()
        local char=LocalPlayer.Character;if not char or not char:FindFirstChild("Head") then return end
        local tp=getPos(targetObj);if not tp then return end
        
        local a0=Instance.new("Attachment");a0.Parent=char.Head
        local a1=Instance.new("Attachment");a1.Parent=targetObj;a1.WorldPosition=tp
        
        local beam=Instance.new("Beam");beam.Attachment0=a0;beam.Attachment1=a1
        beam.Color=ColorSequence.new(color);beam.Width0=0.03;beam.Width1=0.03
        beam.Transparency=NumberSequence.new(0.3);beam.FaceCamera=true;beam.Parent=a0
        
        local dist = (char.Head.Position-tp).Magnitude
        
        -- 标签在射线中间位置（屏幕空间）
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0,200,0,22)
        label.Position = UDim2.new(0.5,-100,0.5,-11)
        label.BackgroundColor3 = Color3.fromRGB(0,0,0,0.4)
        label.TextColor3 = color
        label.Text = name.." "..string.format("%.0fm",dist)
        label.Font = Enum.Font.SourceSansBold
        label.TextSize = 16
        label.ZIndex = 50
        label.Parent = gui
        Instance.new("UICorner", label).CornerRadius = UDim.new(0,4)
        
        table.insert(beamData,{beam=beam,a0=a0,a1=a1,label=label})
    end)
end

function updateBeams()
    clearBeams();if not rayEnabled then return end
    local char=LocalPlayer.Character;if not char or not char:FindFirstChild("Head") then return end;local hp=char.Head.Position
    for _,obj in ipairs(workspace:GetDescendants()) do
        local pos=getPos(obj);if not pos or (hp-pos).Magnitude>150 then continue end
        local color=nil;local nm=nil
        if showDoors and obj:IsA("Model") and obj.Name=="Door" then color=Color3.fromRGB(50,150,255);nm="门"
        elseif showBook and obj.Name=="LiveHintBook" then color=Color3.fromRGB(255,150,50);nm="书"
        elseif showKeys and obj.Name=="KeyObtain" then color=Color3.fromRGB(255,200,0);nm="钥匙"
        elseif showLevers and obj.Name:lower():find("lever") then color=Color3.fromRGB(255,100,255);nm="拉杆"
        elseif showItems then
            if obj:IsA("Tool") then color=Color3.fromRGB(50,255,50);nm="道具"
            elseif obj:IsA("Model") then local n=obj.Name:lower()
                if n:find("candle") and n:find("medium") then
                elseif n:find("gold") or n:find("coin") or n:find("flashlight") or n:find("lighter") or n:find("vitamin") or n:find("lockpick") or n:find("bandage") or n:find("crucifix") or n:find("candle") or n:find("revolver") or n:find("shotgun") or n:find("rifle") or n:find("skeletonkey") or n:find("pills") or n:find("keyobtain") then color=Color3.fromRGB(50,255,50);nm="道具" end end
        elseif showMonsters and obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then local n=obj.Name:lower()
            if n:find("rush") then color=Color3.fromRGB(255,50,50);nm="Rush"
            elseif n:find("ambush") then color=Color3.fromRGB(255,50,50);nm="Ambush"
            elseif n:find("screech") then color=Color3.fromRGB(255,50,50);nm="Screech"
            elseif n:find("figure") then color=Color3.fromRGB(255,50,50);nm="Figure"
            elseif n:find("seek") then color=Color3.fromRGB(255,50,50);nm="Seek"
            elseif n:find("halt") then color=Color3.fromRGB(255,50,50);nm="Halt"
            elseif n:find("eyes") then color=Color3.fromRGB(255,50,50);nm="Eyes"
            elseif n:find("hide") then color=Color3.fromRGB(255,50,50);nm="Hide"
            elseif n:find("dupe") then color=Color3.fromRGB(255,50,50);nm="Dupe"
            elseif n:find("shadow") then color=Color3.fromRGB(255,50,50);nm="Shadow"
            elseif n:find("granny") then color=Color3.fromRGB(255,50,50);nm="Figure"
            elseif obj:FindFirstChild("Humanoid") then color=Color3.fromRGB(255,50,50);nm="怪物" end
        end
        if color then addScreenBeam(obj,color,nm) end
    end
end

function sendChat(msg)
    pcall(function() game:GetService("TextChatService").TextChannels.RBXGeneral:SendAsync(msg) end)
    pcall(function() game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents").SayMessageRequest:FireServer(msg,"All") end)
end

function getMonsterName(obj)
    local n=obj.Name:lower()
    if n:find("ambush") then return"Ambush" elseif n:find("rush") then return"Rush" elseif n:find("screech") then return"Screech" elseif n:find("figure") then return"Figure" elseif n:find("seek") then return"Seek" elseif n:find("halt") then return"Halt" elseif n:find("eyes") then return"Eyes" elseif n:find("hide") then return"Hide" elseif n:find("dupe") then return"Dupe" elseif n:find("shadow") then return"Shadow" elseif n:find("granny") or n:find("blind") or n:find("library") then return"Figure" elseif obj:FindFirstChild("Humanoid") then return"怪物" end
    return nil
end

local popupCooldown = {}
local monsterRepeatCount = {}
local monsterRepeatTime = {}

function updateESP()
    clearAll();if not espEnabled then statusText.Text="ESP关闭";return end
    local td,tb,tk,ti,tl,tm=0,0,0,0,0,0
    
    for _,obj in ipairs(workspace:GetDescendants()) do
        if showDoors and obj:IsA("Model") and obj.Name=="Door" then addESP(obj,Color3.fromRGB(50,150,255),"门");td=td+1 end
        if showBook and obj.Name=="LiveHintBook" then addESP(obj,Color3.fromRGB(255,150,50),"书");tb=tb+1 end
        if showKeys and obj.Name=="KeyObtain" then addESP(obj,Color3.fromRGB(255,200,0),"钥匙");tk=tk+1 end
        if showLevers and obj.Name:lower():find("lever") then addESP(obj,Color3.fromRGB(255,100,255),"拉杆");tl=tl+1 end
        if showItems then
            if obj:IsA("Tool") then addESP(obj,Color3.fromRGB(50,255,50),"道具");ti=ti+1
            elseif obj:IsA("Model") then local n=obj.Name:lower()
                if n:find("candle") and n:find("medium") then
                elseif not n:find("book") and (n:find("gold") or n:find("coin") or n:find("flashlight") or n:find("lighter") or n:find("vitamin") or n:find("lockpick") or n:find("bandage") or n:find("crucifix") or n:find("candle") or n:find("revolver") or n:find("shotgun") or n:find("rifle") or n:find("skeletonkey") or n:find("pills") or n:find("keyobtain")) then addESP(obj,Color3.fromRGB(50,255,50),"道具");ti=ti+1 end end
        end
        if showMonsters and obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then
            local mn=getMonsterName(obj)
            if mn then local pos=obj:FindFirstChildWhichIsA("BasePart")
                if pos then local char=LocalPlayer.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then local dist=(char.HumanoidRootPart.Position-pos.Position).Magnitude;local maxD=(mn=="Rush" or mn=="Ambush") and 500 or 60
                        if dist<maxD then addESP(obj,Color3.fromRGB(255,50,50),mn);tm=tm+1
                            local now=tick()
                            if not monsterRepeatTime[mn] or (now-monsterRepeatTime[mn])>20 then
                                monsterRepeatCount[mn]=1;monsterRepeatTime[mn]=now
                            else
                                monsterRepeatCount[mn]=(monsterRepeatCount[mn]or 0)+1
                            end
                            local cd=(monsterRepeatCount[mn]>=2 and 30 or 10)
                            if not popupCooldown[mn] or (now-popupCooldown[mn])>cd then
                                popupCooldown[mn]=now
                                if monsterRepeatCount[mn]>=2 then monsterRepeatCount[mn]=0 end
                                showPopup(mn, dist)
                            end
                            if alertEnabled then local now2=tick();if not lastAlert[mn] or (now2-lastAlert[mn])>alertCooldown then lastAlert[mn]=now2;sendChat("⚠ "..mn.." 来了！找个地方躲起来！") end end
                        end
                    end
                end
            end
        end
    end
    
    updateBeams();statusText.Text=string.format("🚪%d 📖%d 🔑%d 📦%d 🕹%d 👻%d",td,tb,tk,ti,tl,tm)
end

