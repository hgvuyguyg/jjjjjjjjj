            task.spawn(function()
                local li = 0
                while autoInteract do
                    local n = tick()
                    if n - li < 0.2 then
                        task.wait(0.05)
                        continue
                    end
                    li = n
                    pcall(function()
                        local p = LocalPlayer.Character
                        if not p or not p:FindFirstChild("HumanoidRootPart") then
                            return
                        end
                        local hrp = p.HumanoidRootPart
                        for _, o in ipairs(workspace:GetDescendants()) do
                            if o:IsA("ProximityPrompt") and o.Enabled then
                                local pp = o.Parent
                                if pp then
                                    local po = nil
                                    if pp:IsA("BasePart") then
                                        po = pp.Position
                                    elseif pp:IsA("Model") then
                                        local bp = pp:FindFirstChildWhichIsA("BasePart")
                                        if bp then
                                            po = bp.Position
                                        end
                                    end
                                    if po and (po - hrp.Position).Magnitude < 10 then
                                        local pn = pp.Name:lower()
                                        if pn == "door" or (pp.Parent and pp.Parent.Name:lower() == "door") then
                                            fireproximityprompt(o, 1)
                                        else
                                            local cn = {"wardrobe", "cabinet", "closet", "bed"}
                                            local ic = false
                                            for _, kw in ipairs(cn) do
                                                if pn:find(kw) then
                                                    ic = true
                                                    break
                                                end
                                            end
                                            if not ic then
                                                fireproximityprompt(o)
                                            end
                                        end
                                        break
                                    end
                                end
                            end
                        end
                    end)
                    task.wait(0.05)
                end
            end)
        end
    end
})

