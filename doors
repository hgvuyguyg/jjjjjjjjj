function clearHighlights()
    for _, d in pairs(highlights) do
        pcall(function()
            if d.hl then d.hl:Destroy() end
            if d.bb then d.bb:Destroy() end
            if d.conn then d.conn:Disconnect() end
        end)
    end
    highlights = {}
end

function clearBeams()
    for _, b in pairs(beamData) do
        pcall(function()
            if b.beam then b.beam:Destroy() end
            if b.a0 then b.a0:Destroy() end
            if b.a1 then b.a1:Destroy() end
        end)
    end
    beamData = {}
end

function clearAll()
    clearHighlights()
    clearBeams()
end

function getPos(o)
    if o:IsA("BasePart") then
        return o.Position
    end
    if o:IsA("Model") then
        local p = o:FindFirstChildWhichIsA("BasePart")
        if p then
            return p.Position
        end
    end
    return nil
end

function getDoorNumber(dm)
    if not countedDoors[dm] then
        doorCount = doorCount + 1
        countedDoors[dm] = doorCount
    end
    return countedDoors[dm]
end

function addHighlight(o, c, n)
    pcall(function()
        local hl = Instance.new("Highlight")
        hl.FillColor = c
        hl.FillTransparency = 0.3
        hl.OutlineColor = Color3.new(1, 1, 1)
        hl.OutlineTransparency = 0
        hl.Adornee = o
        hl.Parent = o
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

        local bb = Instance.new("BillboardGui")
        bb.Size = UDim2.new(0, 200, 0, 40)
        bb.AlwaysOnTop = true
        bb.Parent = o

        local nl = Instance.new("TextLabel")
        nl.Size = UDim2.new(1, 0, 0.5, 0)
        nl.BackgroundTransparency = 1
        nl.TextColor3 = Color3.new(1, 1, 1)
        nl.Text = n
        nl.Font = Enum.Font.SourceSansBold
        nl.TextSize = 15
        nl.Parent = bb

        local dl = Instance.new("TextLabel")
        dl.Size = UDim2.new(1, 0, 0.5, 0)
        dl.Position = UDim2.new(0, 0, 0.5, 0)
        dl.BackgroundTransparency = 1
        dl.TextColor3 = Color3.new(0.8, 0.8, 0.8)
        dl.Text = "0m"
        dl.Font = Enum.Font.SourceSans
        dl.TextSize = 12
        dl.Parent = bb

        local cn = RunService.Heartbeat:Connect(function()
            if not o or not o.Parent then
                cn:Disconnect()
                pcall(function()
                    hl:Destroy()
                    bb:Destroy()
                end)
                return
            end
            local ch = LocalPlayer.Character
            if ch and ch:FindFirstChild("HumanoidRootPart") then
                local po = getPos(o)
                if po then
                    pcall(function()
                        dl.Text = string.format("%.1fm", (ch.HumanoidRootPart.Position - po).Magnitude)
                    end)
                end
            end
        end)

        table.insert(highlights, {hl = hl, bb = bb, conn = cn})
    end)
end

function addScreenBeam(o, c)
    pcall(function()
        local ch = LocalPlayer.Character
        if not ch or not ch:FindFirstChild("Head") then
            return
        end
        local tp = getPos(o)
        if not tp then
            return
        end
        local a0 = Instance.new("Attachment", ch.Head)
        local a1 = Instance.new("Attachment", o)
        a1.WorldPosition = tp
        local bm = Instance.new("Beam", a0)
        bm.Attachment0 = a0
        bm.Attachment1 = a1
        bm.Color = ColorSequence.new(c)
        bm.Width0 = 0.03
        bm.Width1 = 0.03
        bm.Transparency = NumberSequence.new(0.3)
        bm.FaceCamera = true
        table.insert(beamData, {beam = bm, a0 = a0, a1 = a1})
    end)
end

function updateBeams()
    clearBeams()
    if not rayEnabled or not espEnabled then
        return
    end
    local ch = LocalPlayer.Character
    if not ch or not ch:FindFirstChild("Head") then
        return
    end
    local hp = ch.Head.Position
    for _, o in ipairs(workspace:GetDescendants()) do
        local po = getPos(o)
        if not po or (hp - po).Magnitude > 200 then
            continue
        end
        local c = nil
        if showDoors and o:IsA("Model") and o.Name == "Door" then
            c = Color3.fromRGB(50, 150, 255)
        elseif showBook and o.Name == "LiveHintBook" then
            c = Color3.fromRGB(255, 150, 50)
        elseif showBattery and o.Name:lower():find("stuff") then
            c = Color3.fromRGB(255, 255, 0)
        elseif showKeys and o.Name == "KeyObtain" then
            c = Color3.fromRGB(255, 200, 0)
        elseif showLevers and o.Name:lower():find("lever") then
            c = Color3.fromRGB(255, 100, 255)
        elseif showItems then
            if o:IsA("Tool") then
                c = Color3.fromRGB(50, 255, 50)
            elseif o:IsA("Model") then
                local n = o.Name:lower()
                if not n:find("book") and (n:find("gold") or n:find("coin") or n:find("flashlight") or n:find("lighter") or n:find("vitamin") or n:find("lockpick") or n:find("bandage") or n:find("crucifix") or n:find("revolver") or n:find("shotgun") or n:find("rifle") or n:find("skeletonkey") or n:find("pills")) then
                    c = Color3.fromRGB(50, 255, 50)
                end
            end
        elseif showMonsters and o:IsA("Model") and not Players:GetPlayerFromCharacter(o) then
            local mn = getMonsterName(o)
            if mn then
                c = Color3.fromRGB(255, 50, 50)
            end
        end
        if c then
            addScreenBeam(o, c)
        end
    end
    if showTeammates then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
                addScreenBeam(p.Character, Color3.new(1, 1, 1))
            end
        end
    end
end

function getMonsterName(o)
    local n = o.Name:lower()
    if n:find("ambush") then
        return "Ambush"
    elseif n:find("rush") then
        return "Rush"
    elseif n:find("screech") or n:find("psst") then
        return "Screech"
    elseif n:find("figure") or n:find("blind") or n:find("library") then
        return "Figure"
    elseif n:find("seek") then
        return "Seek"
    elseif n:find("halt") then
        return "Halt"
    elseif n:find("eyes") then
        return "Eyes"
    elseif n:find("hide") then
        return "Hide"
    elseif n:find("dupe") then
        return "Dupe"
    elseif n:find("shadow") then
        return "Shadow"
    elseif n:find("granny") then
        return "Figure"
    elseif o:FindFirstChild("Humanoid") then
        return "怪物"
    end
    return nil
end

function updateESP()
    clearHighlights()
    if not espEnabled then
        return
    end
    for _, o in ipairs(workspace:GetDescendants()) do
        if showDoors and o:IsA("Model") and o.Name == "Door" then
            addHighlight(o, Color3.fromRGB(50, 150, 255), "门#" .. getDoorNumber(o))
        elseif showBook and o.Name == "LiveHintBook" then
            addHighlight(o, Color3.fromRGB(255, 150, 50), "书")
        elseif showBattery and o.Name:lower():find("stuff") then
            addHighlight(o, Color3.fromRGB(255, 255, 0), "电池")
        elseif showKeys and o.Name == "KeyObtain" then
            addHighlight(o, Color3.fromRGB(255, 200, 0), "钥匙")
        elseif showLevers and o.Name:lower():find("lever") then
            addHighlight(o, Color3.fromRGB(255, 100, 255), "拉杆")
        elseif showItems then
            if o:IsA("Tool") then
                addHighlight(o, Color3.fromRGB(50, 255, 50), "道具")
            elseif o:IsA("Model") then
                local n = o.Name:lower()
                if not n:find("book") and (n:find("gold") or n:find("coin") or n:find("flashlight") or n:find("lighter") or n:find("vitamin") or n:find("lockpick") or n:find("bandage") or n:find("crucifix") or n:find("revolver") or n:find("shotgun") or n:find("rifle") or n:find("skeletonkey") or n:find("pills")) then
                    addHighlight(o, Color3.fromRGB(50, 255, 50), "道具")
                end
            end
        elseif showMonsters and o:IsA("Model") and not Players:GetPlayerFromCharacter(o) then
            local mn = getMonsterName(o)
            if mn then
                local po = o:FindFirstChildWhichIsA("BasePart")
                if po and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (LocalPlayer.Character.HumanoidRootPart.Position - po.Position).Magnitude
                    local md = (mn == "Rush" or mn == "Ambush") and 500 or (mn == "Seek") and 300 or (mn == "Screech") and 40 or 80
                    if d < md then
                        addHighlight(o, Color3.fromRGB(255, 50, 50), mn)
                    end
                end
            end
        end
    end
    if showTeammates then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                addHighlight(p.Character, Color3.new(1, 1, 1), p.Name)
            end
        end
    end
end

