    B.MouseButton1Click:Connect(function() ts = not ts; if ts then B.BackgroundColor3 = Color3.fromRGB(76, 175, 80); B.Text = "停止"; cn = onExecute(true) else B.BackgroundColor3 = Color3.fromRGB(255, 140, 0); B.Text = btnText or "执行"; onExecute(false); if cn then pcall(function() cn:Disconnect() end); cn = nil end end end)
    B.MouseEnter:Connect(function() if not ts then B.BackgroundColor3 = Color3.fromRGB(255, 160, 20) end end)
    B.MouseLeave:Connect(function() if not ts then B.BackgroundColor3 = Color3.fromRGB(255, 140, 0) end end)
