function triggerRushTest()
    if testRushActive then return end
    testRushActive = true
    print("🔴 触发Rush测试！")
    showPopup("Rush")
    pcall(function()
        local sound = Instance.new("Sound")
        sound.SoundId = "rbxassetid://9126074485"
        sound.Volume = 2
        sound.Parent = screenGui
        sound:Play()
        task.wait(1)
        sound:Destroy()
    end)
    task.wait(2)
    testRushActive = false
    print("✅ Rush测试完成")
end

game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.K then
