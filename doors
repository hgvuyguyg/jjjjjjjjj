function clearAll()
    for _, d in pairs(highlights) do
        pcall(function()
            if d.hl then d.hl:Destroy() end
            if d.bb then d.bb:Destroy() end
            if d.conn then d.conn:Disconnect() end
        end)
    end
    highlights = {}
end

function addESP(obj, color, name)
    pcall(function()
        local hl = Instance.new("Highlight")
        hl.FillColor = color
        hl.FillTransparency = 0.3
        hl.OutlineColor = Color3.fromRGB(255,255,255)
        hl.OutlineTransparency = 0
        hl.Adornee = obj
        hl.Parent = obj
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        
        local bb = Instance.new("BillboardGui")
        bb.Size = UDim2.new(0,200,0,30)
        bb.AlwaysOnTop = true
        bb.Parent = obj
        
        local lb = Instance.new("TextLabel")
        lb.Size = UDim2.new(1,0,1,0)
        lb.BackgroundTransparency = 1
        lb.TextColor3 = Color3.fromRGB(255,255,255)
        lb.TextStrokeTransparency = 0
        lb.TextStrokeColor3 = Color3.fromRGB(0,0,0)
        lb.Font = Enum.Font.SourceSansBold
        lb.TextSize = 16
        lb.Parent = bb
        
        local conn = RunService.Heartbeat:Connect(function()
            if not obj or not obj.Parent then
                conn:Disconnect(); hl:Destroy(); bb:Destroy(); return
            end
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local pos
                if obj:IsA("BasePart") then pos = obj.Position
                elseif obj:IsA("Model") then
                    local p = obj:FindFirstChildWhichIsA("BasePart")
                    if p then pos = p.Position end
                end
                if pos then
                    lb.Text = string.format("%s %.1fm", name, (char.HumanoidRootPart.Position - pos).Magnitude)
                end
            end
        end)
        
        table.insert(highlights, {hl=hl, bb=bb, conn=conn})
    end)
end

local function getMonsterName(obj)
    local n = obj.Name:lower()
    if n:find("ambush") then return "Ambush" end
    if n:find("rush") then return "Rush" end
    if n:find("screech") then return "Screech" end
    if n:find("figure") then return "Figure" end
    if n:find("seek") then return "Seek" end
    if n:find("halt") then return "Halt" end
    if n:find("eyes") then return "Eyes" end
    if n:find("hide") then return "Hide" end
    if n:find("dupe") then return "Dupe" end
    if n:find("shadow") then return "Shadow" end
    if n:find("granny") or n:find("blind") or n:find("library") then return "Figure" end
    if obj:FindFirstChild("Humanoid") then return "怪物" end
    return nil
end

function updateESP()
    clearAll()
    if not espEnabled then warn.Visible = false; return end
    
    local nm = nil
    local nd = 999
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        -- 门
        if showDoors and obj:IsA("Model") and obj.Name == "Door" then
            addESP(obj, Color3.fromRGB(50,150,255), "门")
        end
        -- 钥匙
        if showKeys then
            local n = obj.Name:lower()
            if not n:find("typewriter") and n:find("key") then
                addESP(obj, Color3.fromRGB(255,200,0), "钥匙")
            end
        end
        -- 道具
        if showItems then
            if obj:IsA("Tool") then
                addESP(obj, Color3.fromRGB(50,255,50), "道具")
            elseif obj:IsA("Model") then
                local n = obj.Name:lower()
                if not n:find("book") then
                    if n:find("gold") or n:find("coin") then
                        addESP(obj, Color3.fromRGB(50,255,50), "道具")
                    else
                        for _, item in ipairs({"flashlight","lighter","vitamin","lockpick","bandage","crucifix","revolver","shotgun","rifle","skeletonkey","pills"}) do
                            if n:find(item) then addESP(obj, Color3.fromRGB(50,255,50), "道具"); break end
                        end
                    end
                end
            end
        end
        -- 怪物
        if showMonsters and obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then
            local mn = getMonsterName(obj)
            if mn then
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local pos = obj:FindFirstChildWhichIsA("BasePart")
                    if pos then
                        local dist = (char.HumanoidRootPart.Position - pos.Position).Magnitude
                        local maxD = (mn=="Rush" or mn=="Ambush") and 300 or 50
                        if dist < maxD then
                            addESP(obj, Color3.fromRGB(255,50,50), mn)
                            if dist < nd then nd = dist; nm = mn end
                        end
                    end
                end
            end
        end
    end
    
    if nm then
        warn.Visible = true
        if nd < 8 then
            warnText.Text = "⚠ "..nm.." 来了! "..string.format("%.1fm",nd).." ⚠"
            warn.BackgroundColor3 = Color3.fromRGB(255,0,0)
        elseif nd < 25 then
            warnText.Text = "⚠ "..nm.." "..string.format("%.1fm",nd).." ⚠"
            warn.BackgroundColor3 = Color3.fromRGB(255,80,0)
        else
            warnText.Text = nm.." "..string.format("%.1fm",nd)
            warn.BackgroundColor3 = Color3.fromRGB(200,120,0)
        end
    else
        warn.Visible = false
    end
end

-- 夜视
spawn(function()
    while true do
        if nightVision then
            pcall(function()
                local a = (Lighting.Ambient.R + Lighting.Ambient.G + Lighting.Ambient.B) / 3
                local o = (Lighting.OutdoorAmbient.R + Lighting.OutdoorAmbient.G + Lighting.OutdoorAmbient.B) / 3
                if a < 0.3 and o < 0.3 then
                    Lighting.Brightness = 5
                    Lighting.ClockTime = 14
                    Lighting.FogEnd = 999999
                    Lighting.ExposureCompensation = 1.5
                else
                    Lighting.Brightness = 1
                    Lighting.FogEnd = 500
                    Lighting.ExposureCompensation = 0
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- ESP循环
spawn(function()
    while true do
        if espEnabled then updateESP() end
        task.wait(0.5)
    end
end)

