                if p==popup then 
                    table.remove(activePopups,i)
                    break 
                end 
            end
            popup:Destroy()
            for _,p in ipairs(activePopups)do
                TweenService:Create(p,TweenInfo.new(0.25),{Position=UDim2.new(0,0,0,p.Position.Y.Offset-72)}):Play()
            end
