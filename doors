function clearAll()
    for _, d in pairs(highlights) do
        pcall(function()
            if d.hl then d.hl:Destroy() end
            if d.bb then d.bb:Destroy() end
            if d.conn then d.conn:Disconnect() end
        end)
    end
    highlights = {}
    clearBeams()
end

function clearBeams()
    for _, b in pairs(beamData) do
        pcall(function()
            if b.beam then b.beam:Destroy() end
            if b.a0 then b.a0:Destroy() end
            if b.a1 then b.a1:Destroy() end
        end)
    end
    beamData = {}
end

function getPos(obj)
    if obj:IsA("BasePart") then return obj.Position end
    if obj:IsA("Model") then
        local p = obj:FindFirstChildWhichIsA("BasePart")
        if p then return p.Position end
    end
    return nil
end

function addESP(obj, color, name)
    pcall(function()
        local hl = Instance.new("Highlight")
        hl.FillColor = color
        hl.FillTransparency = 0.3
        hl.OutlineColor = Color3.fromRGB(255,255,255)
        hl.OutlineTransparency = 0
        hl.Adornee = obj
        hl.Parent = obj
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        
        local bb = Instance.new("BillboardGui")
        bb.Size = UDim2.new(0,200,0,30)
        bb.AlwaysOnTop = true
        bb.Parent = obj
        
        local lb = Instance.new("TextLabel")
        lb.Size = UDim2.new(1,0,1,0)
        lb.BackgroundTransparency = 1
        lb.TextColor3 = Color3.fromRGB(255,255,255)
        lb.TextStrokeTransparency = 0
        lb.TextStrokeColor3 = Color3.fromRGB(0,0,0)
        lb.Font = Enum.Font.SourceSansBold
        lb.TextSize = 16
        lb.Parent = bb
        
        local conn = RunService.Heartbeat:Connect(function()
            if not obj or not obj.Parent then
                conn:Disconnect(); hl:Destroy(); bb:Destroy(); return
            end
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local pos = getPos(obj)
                if pos then
                    lb.Text = string.format("%s %.1fm", name, (char.HumanoidRootPart.Position - pos).Magnitude)
                end
            end
        end)
        
        table.insert(highlights, {hl=hl, bb=bb, conn=conn})
    end)
end

function addBeam(targetObj, color)
    pcall(function()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("Head") then return end
        local targetPos = getPos(targetObj)
        if not targetPos then return end
        
        local a0 = Instance.new("Attachment")
        a0.Parent = char.Head
        local a1 = Instance.new("Attachment")
        a1.Parent = targetObj
        a1.WorldPosition = targetPos
        
        local beam = Instance.new("Beam")
        beam.Attachment0 = a0
        beam.Attachment1 = a1
        beam.Color = ColorSequence.new(color)
        beam.Width0 = 0.04
        beam.Width1 = 0.04
        beam.Transparency = NumberSequence.new(0.4)
        beam.FaceCamera = true
        beam.Parent = a0
        
        table.insert(beamData, {beam=beam, a0=a0, a1=a1})
    end)
end

function updateBeams()
    clearBeams()
    if not rayEnabled then return end
    
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("Head") then return end
    local hp = char.Head.Position
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        local pos = getPos(obj)
        if not pos or (hp - pos).Magnitude > 150 then continue end
        
        local color = nil
        if showDoors and obj:IsA("Model") and obj.Name == "Door" then
            color = Color3.fromRGB(50,150,255)
        elseif showKeys and obj.Name == "KeyObtain" then
            color = Color3.fromRGB(255,200,0)
        elseif showLevers and obj.Name:lower():find("lever") then
            color = Color3.fromRGB(255,100,255)
        elseif showItems then
            if obj:IsA("Tool") then color = Color3.fromRGB(50,255,50)
            elseif obj:IsA("Model") then
                local n = obj.Name:lower()
                if n:find("gold") or n:find("coin") or n:find("flashlight") or n:find("lighter") or n:find("vitamin") or n:find("lockpick") or n:find("bandage") or n:find("crucifix") or n:find("revolver") or n:find("shotgun") or n:find("rifle") or n:find("skeletonkey") or n:find("pills") then
                    color = Color3.fromRGB(50,255,50)
                end
            end
        elseif showMonsters and obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then
            local n = obj.Name:lower()
            if n:find("rush") or n:find("ambush") or n:find("screech") or n:find("figure") or n:find("seek") or n:find("halt") or n:find("eyes") or n:find("hide") or n:find("dupe") or n:find("shadow") or obj:FindFirstChild("Humanoid") then
                color = Color3.fromRGB(255,50,50)
            end
        end
        if color then addBeam(obj, color) end
    end
end

function getMonsterName(obj)
    local n = obj.Name:lower()
    if n:find("ambush") then return "Ambush" end
    if n:find("rush") then return "Rush" end
    if n:find("screech") then return "Screech" end
    if n:find("figure") then return "Figure" end
    if n:find("seek") then return "Seek" end
    if n:find("halt") then return "Halt" end
    if n:find("eyes") then return "Eyes" end
    if n:find("hide") then return "Hide" end
    if n:find("dupe") then return "Dupe" end
    if n:find("shadow") then return "Shadow" end
    if obj:FindFirstChild("Humanoid") then return "怪物" end
    return nil
end

function updateESP()
    clearAll()
    if not espEnabled then warnFrame.Visible = false; return end
    
    local nm = nil
    local nd = 999
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if showDoors and obj:IsA("Model") and obj.Name == "Door" then
            addESP(obj, Color3.fromRGB(50,150,255), "门")
        end
        if showKeys and obj.Name == "KeyObtain" then
            addESP(obj, Color3.fromRGB(255,200,0), "钥匙")
        end
        if showLevers and obj.Name:lower():find("lever") then
            addESP(obj, Color3.fromRGB(255,100,255), "拉杆")
        end
        if showItems then
            if obj:IsA("Tool") then
                addESP(obj, Color3.fromRGB(50,255,50), "道具")
            elseif obj:IsA("Model") then
                local n = obj.Name:lower()
                if not n:find("book") and (n:find("gold") or n:find("coin") or n:find("flashlight") or n:find("lighter") or n:find("vitamin") or n:find("lockpick") or n:find("bandage") or n:find("crucifix") or n:find("revolver") or n:find("shotgun") or n:find("rifle") or n:find("skeletonkey") or n:find("pills")) then
                    addESP(obj, Color3.fromRGB(50,255,50), "道具")
                end
            end
        end
        if showMonsters and obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then
            local mn = getMonsterName(obj)
            if mn then
                local pos = obj:FindFirstChildWhichIsA("BasePart")
                if pos then
                    local char = LocalPlayer.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        local dist = (char.HumanoidRootPart.Position - pos.Position).Magnitude
                        local maxD = (mn=="Rush" or mn=="Ambush") and 300 or 50
                        if dist < maxD then
                            addESP(obj, Color3.fromRGB(255,50,50), mn)
                            if dist < nd then nd = dist; nm = mn end
                        end
                    end
                end
            end
        end
    end
    
    updateBeams()
    
    if nm then
        warnFrame.Visible = true
        if nd < 8 then
            warnText.Text = "⚠ "..nm.." 来了! "..string.format("%.1fm",nd).." ⚠"
            warnFrame.BackgroundColor3 = Color3.fromRGB(255,0,0)
        elseif nd < 25 then
            warnText.Text = "⚠ "..nm.." "..string.format("%.1fm",nd).." ⚠"
            warnFrame.BackgroundColor3 = Color3.fromRGB(255,80,0)
        else
            warnText.Text = nm.." "..string.format("%.1fm",nd)
            warnFrame.BackgroundColor3 = Color3.fromRGB(200,120,0)
        end
    else
        warnFrame.Visible = false
    end
end

