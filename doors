local doorCount = 0
local countedDoors = {}

function doors_clearAll()
    for _, d in pairs(doors_highlights) do pcall(function() if d.hl then d.hl:Destroy() end if d.bb then d.bb:Destroy() end if d.conn then d.conn:Disconnect() end end) end
    doors_highlights = {}
end
function doors_clearBeams()
    for _, b in pairs(doors_beamData) do pcall(function() if b.beam then b.beam:Destroy() end if b.a0 then b.a0:Destroy() end if b.a1 then b.a1:Destroy() end end) end
    doors_beamData = {}
end
function doors_getPos(o)
    if o:IsA("BasePart") then return o.Position end
    if o:IsA("Model") then local p = o:FindFirstChildWhichIsA("BasePart"); if p then return p.Position end end
    return nil
end

function doors_getDoorNumber(doorModel)
    if not countedDoors[doorModel] then doorCount = doorCount + 1; countedDoors[doorModel] = doorCount end
    return countedDoors[doorModel]
end

function doors_getMonsterName(o)
    local n = o.Name:lower()
    if n:find("ambush") then return "Ambush"
    elseif n:find("rush") then return "Rush"
    elseif n:find("screech") or n:find("psst") or n:find("scream") then return "Screech"
    elseif n:find("figure") or n:find("blind") or n:find("library") then return "Figure"
    elseif n:find("seek") then return "Seek"
    elseif n:find("halt") then return "Halt"
    elseif n:find("eyes") then return "Eyes"
    elseif n:find("hide") then return "Hide"
    elseif n:find("dupe") then return "Dupe"
    elseif n:find("shadow") then return "Shadow"
    elseif n:find("granny") then return "Figure"
    elseif o:FindFirstChild("Humanoid") and o:FindFirstChild("Head") then
        if o.Head.Size.Magnitude < 3 then return "Screech" end
        return "怪物"
    end
    return nil
end

function doors_addESP(o, c, n)
    pcall(function()
        local hl = Instance.new("Highlight"); hl.FillColor = c; hl.FillTransparency = 0.3; hl.OutlineColor = Color3.fromRGB(255,255,255); hl.OutlineTransparency = 0; hl.Adornee = o; hl.Parent = o; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        local bb = Instance.new("BillboardGui"); bb.Size = UDim2.new(0,200,0,30); bb.AlwaysOnTop = true; bb.Parent = o
        local lb = Instance.new("TextLabel"); lb.Size = UDim2.new(1,0,1,0); lb.BackgroundTransparency = 1; lb.TextColor3 = Color3.fromRGB(255,255,255); lb.Font = Enum.Font.SourceSansBold; lb.TextSize = 16; lb.Parent = bb
        local conn = RunService.Heartbeat:Connect(function()
            if not o or not o.Parent then conn:Disconnect(); pcall(function() hl:Destroy() bb:Destroy() end); return end
            local ch = LocalPlayer.Character; if ch and ch:FindFirstChild("HumanoidRootPart") then local po = doors_getPos(o)
                if po then pcall(function() lb.Text = string.format("%s %.1fm", n, (ch.HumanoidRootPart.Position - po).Magnitude) end) end
            end
        end)
        table.insert(doors_highlights, {hl=hl, bb=bb, conn=conn})
    end)
end

function doors_addScreenBeam(o, c)
    pcall(function()
        local ch = LocalPlayer.Character; if not ch or not ch:FindFirstChild("Head") then return end
        local tp = doors_getPos(o); if not tp then return end
        local a0 = Instance.new("Attachment", ch.Head); local a1 = Instance.new("Attachment", o); a1.WorldPosition = tp
        local bm = Instance.new("Beam", a0); bm.Attachment0 = a0; bm.Attachment1 = a1
        bm.Color = ColorSequence.new(c); bm.Width0 = 0.03; bm.Width1 = 0.03
        bm.Transparency = NumberSequence.new(0.3); bm.FaceCamera = true
        table.insert(doors_beamData, {beam=bm, a0=a0, a1=a1})
    end)
end

function doors_updateBeams()
    doors_clearBeams(); if not doors_rayEnabled or not doors_espEnabled then return end
    local ch = LocalPlayer.Character; if not ch or not ch:FindFirstChild("Head") then return end; local hp = ch.Head.Position
    for _, o in ipairs(workspace:GetDescendants()) do local po = doors_getPos(o); if po and (hp - po).Magnitude <= 200 then local c = nil
        if doors_showDoors and o:IsA("Model") and o.Name == "Door" then c = Color3.fromRGB(50,150,255)
        elseif doors_showBook and o.Name == "LiveHintBook" and not (o.Parent and o.Parent.Name == "LibraryBooks") then c = Color3.fromRGB(255,150,50)
        elseif doors_showBattery and o.Name:lower():find("stuff") then c = Color3.fromRGB(255,255,0)
        elseif doors_showKeys and o.Name == "KeyObtain" then c = Color3.fromRGB(255,200,0)
        elseif doors_showLevers and o.Name:lower():find("lever") then c = Color3.fromRGB(255,100,255)
        elseif doors_showItems then if o:IsA("Tool") then c = Color3.fromRGB(50,255,50) elseif o:IsA("Model") then local n = o.Name:lower(); if not n:find("book") and (n:find("gold") or n:find("coin") or n:find("flashlight") or n:find("lighter") or n:find("vitamin") or n:find("lockpick") or n:find("bandage") or n:find("crucifix") or n:find("revolver") or n:find("shotgun") or n:find("rifle") or n:find("skeletonkey") or n:find("pills")) then c = Color3.fromRGB(50,255,50) end end
        elseif doors_showMonsters and o:IsA("Model") and not Players:GetPlayerFromCharacter(o) then local mn = doors_getMonsterName(o); if mn then c = Color3.fromRGB(255,50,50) end end
        if c then doors_addScreenBeam(o, c) end end
    end
end

function doors_updateESP()
    doors_clearAll()
    if not doors_espEnabled then return end
    for _, o in ipairs(workspace:GetDescendants()) do
        if doors_showDoors and o:IsA("Model") and o.Name == "Door" then
            doors_addESP(o, Color3.fromRGB(50,150,255), "门#" .. doors_getDoorNumber(o))
        elseif doors_showBook and o.Name == "LiveHintBook" then
            if not (o.Parent and o.Parent.Name == "LibraryBooks") then doors_addESP(o, Color3.fromRGB(255,150,50), "书") end
        elseif doors_showBattery and o:IsA("Model") and o.Name:lower():find("stuff") then doors_addESP(o, Color3.fromRGB(255,255,0), "电池")
        elseif doors_showKeys and o.Name == "KeyObtain" then doors_addESP(o, Color3.fromRGB(255,200,0), "钥匙")
        elseif doors_showLevers and o.Name:lower():find("lever") then doors_addESP(o, Color3.fromRGB(255,100,255), "拉杆")
        elseif doors_showItems then
            if o:IsA("Tool") then doors_addESP(o, Color3.fromRGB(50,255,50), "道具")
            elseif o:IsA("Model") then local n = o.Name:lower()
                if not n:find("book") and not n:find("library") and (n:find("gold") or n:find("coin") or n:find("flashlight") or n:find("lighter") or n:find("vitamin") or n:find("lockpick") or n:find("bandage") or n:find("crucifix") or n:find("revolver") or n:find("shotgun") or n:find("rifle") or n:find("skeletonkey") or n:find("pills")) then doors_addESP(o, Color3.fromRGB(50,255,50), "道具") end end
        elseif doors_showMonsters and o:IsA("Model") and not Players:GetPlayerFromCharacter(o) then
            local mn = doors_getMonsterName(o)
            if mn then
                local po = o:FindFirstChildWhichIsA("BasePart")
                if po then
                    local ch = LocalPlayer.Character
                    if ch and ch:FindFirstChild("HumanoidRootPart") then
                        local d = (ch.HumanoidRootPart.Position - po.Position).Magnitude
                        local md = (mn == "Rush" or mn == "Ambush") and 500 or (mn == "Seek") and 300 or (mn == "Screech") and 40 or 80
                        if d < md then doors_addESP(o, Color3.fromRGB(255,50,50), mn) end
                    end
                end
            end
        end
    end
end

spawn(function() while true do if doors_espEnabled then doors_updateESP(); if doors_rayEnabled then doors_updateBeams() end end; task.wait(0.5) end end)
