    Btn.Text = btnText or "执行"; Btn.TextColor3 = Color3.fromRGB(255, 255, 255); Btn.Font = Enum.Font.GothamBold; Btn.TextSize = 10
    Btn.BackgroundColor3 = Color3.fromRGB(255, 140, 0); Btn.BorderSizePixel = 0; Btn.ZIndex = 9; Btn.AutoButtonColor = false; Btn.Parent = Card
