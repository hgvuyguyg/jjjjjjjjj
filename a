    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then local mn = doors_getMonsterName(obj)
            if mn then local pos = obj:FindFirstChildWhichIsA("BasePart")
                if pos then local char = LocalPlayer.Character; if char and char:FindFirstChild("HumanoidRootPart") then local dist = (char.HumanoidRootPart.Position - pos.Position).Magnitude; local maxD = (mn=="Rush" or mn=="Ambush") and 500 or 60
                    if dist < maxD then local now = tick()
                        if not doors_popupCooldown[mn] or (now - doors_popupCooldown[mn]) > 30 then doors_popupCooldown[mn] = now; doors_showPopup(mn) end
                    end
                end end end
        end
    end
end
