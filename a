    local DescText = Instance.new("TextLabel"); DescText.Size = UDim2.new(1, -100, 0, 13); DescText.Position = UDim2.new(0, 44, 0, 22)
    DescText.Text = desc; DescText.TextColor3 = Color3.fromRGB(130, 130, 130); DescText.Font = Enum.Font.Gotham; DescText.TextSize = 9
    DescText.BackgroundTransparency = 1; DescText.TextXAlignment = Enum.TextXAlignment.Left; DescText.ZIndex = 8; DescText.Parent = Card
