            for _, p in ipairs(doors_activePopups) do TweenService:Create(p, TweenInfo.new(0.25), {Position = UDim2.new(0, 0, 0, p.Position.Y.Offset - 72)}):Play() end
        end)
    end)
end
local doors_popupCooldown = {}
