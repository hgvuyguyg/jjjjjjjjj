    local toggleState = false; local conn = nil
    Btn.MouseButton1Click:Connect(function()
        toggleState = not toggleState
        if toggleState then Btn.BackgroundColor3 = Color3.fromRGB(76, 175, 80); Btn.Text = "停止"; conn = onExecute(true)
        else Btn.BackgroundColor3 = Color3.fromRGB(255, 140, 0); Btn.Text = btnText or "执行"; onExecute(false); if conn then conn:Disconnect(); conn = nil end end
    end)
    Btn.MouseEnter:Connect(function() if not toggleState then Btn.BackgroundColor3 = Color3.fromRGB(255, 160, 20) end end)
    Btn.MouseLeave:Connect(function() if not toggleState then Btn.BackgroundColor3 = Color3.fromRGB(255, 140, 0) end end)
end

