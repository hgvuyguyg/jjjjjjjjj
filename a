doors_createMainCard("防滑模式", "停止移动时定在原地0.01秒", "🧊", function(state)
    doors_antiSlipEnabled = state
    if state then
        local wasMoving = false
        local conn = RunService.RenderStepped:Connect(function()
            if not doors_antiSlipEnabled then return end
            local c = LocalPlayer.Character; if not c or not c:FindFirstChild("HumanoidRootPart") or not c:FindFirstChild("Humanoid") then return end
            local hrp = c.HumanoidRootPart; local hum = c.Humanoid
            local vel = hrp.Velocity; local speedXZ = Vector3.new(vel.X, 0, vel.Z).Magnitude
            if speedXZ > 0.5 then wasMoving = true
            elseif wasMoving and speedXZ < 0.5 then
                hrp.Velocity = Vector3.new(0, vel.Y, 0); hum:MoveTo(hrp.Position)
                wasMoving = false
            end
        end)
        return conn
    end
end, "开启")

doors_createMainCard("自动互动", "自动按E互动附近物品", "🤖", function(state)
    doors_autoInteractEnabled = state
    if state then
        local conn = RunService.RenderStepped:Connect(function()
            if not doors_autoInteractEnabled then return end
            local c = LocalPlayer.Character; if not c or not c:FindFirstChild("HumanoidRootPart") then return end
            local hrp = c.HumanoidRootPart
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") and obj.Enabled then
                    local p = obj.Parent; if p and p:IsA("BasePart") or p:IsA("Model") then
                        local pos = p:IsA("Model") and (p:FindFirstChildWhichIsA("BasePart") and p:FindFirstChildWhichIsA("BasePart").Position) or p.Position
                        if pos and (pos - hrp.Position).Magnitude < 5 then fireproximityprompt(obj) end
                    end
                end
            end
        end)
        return conn
    end
end, "开启")

