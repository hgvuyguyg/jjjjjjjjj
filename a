function doors_updateBeams()
    doors_clearBeams(); if not doors_rayEnabled or not doors_espEnabled then return end
    local char = LocalPlayer.Character; if not char or not char:FindFirstChild("Head") then return end; local hp = char.Head.Position
    for _, obj in ipairs(workspace:GetDescendants()) do
        local pos = doors_getPos(obj); if not pos or (hp - pos).Magnitude > 200 then continue end
        local color = nil
        if doors_showDoors and obj:IsA("Model") and obj.Name == "Door" then color = Color3.fromRGB(50,150,255)
        elseif doors_showBook and obj.Name == "LiveHintBook" then color = Color3.fromRGB(255,150,50)
        elseif doors_showBattery and obj.Name:lower():find("stuff") then color = Color3.fromRGB(255,255,0)
        elseif doors_showKeys and obj.Name == "KeyObtain" then color = Color3.fromRGB(255,200,0)
        elseif doors_showLevers and obj.Name:lower():find("lever") then color = Color3.fromRGB(255,100,255)
        elseif doors_showItems then
            if obj:IsA("Tool") then color = Color3.fromRGB(50,255,50)
            elseif obj:IsA("Model") then local n = obj.Name:lower()
                if n:find("gold") or n:find("coin") or n:find("flashlight") or n:find("lighter") or n:find("vitamin") or n:find("lockpick") or n:find("bandage") or n:find("crucifix") or n:find("revolver") or n:find("shotgun") or n:find("rifle") or n:find("skeletonkey") or n:find("pills") then color = Color3.fromRGB(50,255,50) end end
        elseif doors_showMonsters and obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then local n = obj.Name:lower()
            if n:find("rush") or n:find("ambush") or n:find("screech") or n:find("figure") or n:find("seek") or n:find("halt") or n:find("eyes") or n:find("hide") or n:find("dupe") or n:find("shadow") or n:find("granny") or obj:FindFirstChild("Humanoid") then color = Color3.fromRGB(255,50,50) end
