        if doors_showKeys and obj.Name == "KeyObtain" then doors_addESP(obj, Color3.fromRGB(255,200,0), "钥匙") end
        if doors_showLevers and obj.Name:lower():find("lever") then doors_addESP(obj, Color3.fromRGB(255,100,255), "拉杆") end
        if doors_showItems then
            if obj:IsA("Tool") then doors_addESP(obj, Color3.fromRGB(50,255,50), "道具")
            elseif obj:IsA("Model") then local n = obj.Name:lower()
                if not n:find("book") and (n:find("gold") or n:find("coin") or n:find("flashlight") or n:find("lighter") or n:find("vitamin") or n:find("lockpick") or n:find("bandage") or n:find("crucifix") or n:find("revolver") or n:find("shotgun") or n:find("rifle") or n:find("skeletonkey") or n:find("pills")) then doors_addESP(obj, Color3.fromRGB(50,255,50), "道具") end end
        end
        if doors_showMonsters and obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then local mn = doors_getMonsterName(obj)
            if mn then local pos = obj:FindFirstChildWhichIsA("BasePart")
                if pos then local char = LocalPlayer.Character; if char and char:FindFirstChild("HumanoidRootPart") then local dist = (char.HumanoidRootPart.Position - pos.Position).Magnitude; local maxD = (mn=="Rush" or mn=="Ambush") and 500 or 60
