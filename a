    end
end
function doors_getMonsterName(obj)
    local n = obj.Name:lower()
    if n:find("ambush") then return "Ambush" elseif n:find("rush") then return "Rush" elseif n:find("screech") then return "Screech" elseif n:find("figure") then return "Figure" elseif n:find("seek") then return "Seek" elseif n:find("halt") then return "Halt" elseif n:find("eyes") then return "Eyes" elseif n:find("hide") then return "Hide" elseif n:find("dupe") then return "Dupe" elseif n:find("shadow") then return "Shadow" elseif n:find("granny") or n:find("blind") or n:find("library") then return "Figure" elseif obj:FindFirstChild("Humanoid") then return "怪物" end
    return nil
end
function doors_updateESP()
    doors_clearAll(); if not doors_espEnabled then return end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if doors_showDoors and obj:IsA("Model") and obj.Name == "Door" then doors_addESP(obj, Color3.fromRGB(50,150,255), "门") end
