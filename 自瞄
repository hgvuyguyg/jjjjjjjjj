function getPlayerFromCharacter(character)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character == character then
            return plr
        end
    end
    return nil
end

function createESPForPlayer(targetPlayer)
    local character = targetPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local head = character:FindFirstChild("Head")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not head or not rootPart then return end
    
    local espData = {
        player = targetPlayer,
        character = character,
        labels = {},
        boxes = {},
        lines = {}
    }
    
    espObjects[targetPlayer] = espData
    
    if nameEspEnabled then
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Name = "ESP_Name_" .. targetPlayer.Name
        nameLabel.Text = targetPlayer.Name
        nameLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        nameLabel.TextSize = 14
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.BackgroundTransparency = 1
        nameLabel.TextStrokeTransparency = 0
        nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
        nameLabel.ZIndex = 10
        nameLabel.Parent = gui
        table.insert(espData.labels, nameLabel)
    end
    
    if boxEspEnabled then
        local boxFrame = Instance.new("Frame")
        boxFrame.Name = "ESP_Box_" .. targetPlayer.Name
        boxFrame.BackgroundTransparency = 0.8
        boxFrame.BackgroundColor3 = Color3.fromRGB(148, 0, 211)
        boxFrame.BorderSizePixel = 2
        boxFrame.BorderColor3 = Color3.fromRGB(148, 0, 211)
        boxFrame.ZIndex = 5
        boxFrame.Parent = gui
        table.insert(espData.boxes, boxFrame)
    end
    
    if skeletonEspEnabled then
        local bodyParts = {
            "Head", "UpperTorso", "LowerTorso", "LeftUpperArm", "RightUpperArm",
            "LeftLowerArm", "RightLowerArm", "LeftUpperLeg", "RightUpperLeg",
            "LeftLowerLeg", "RightLowerLeg", "LeftFoot", "RightFoot"
        }
        
        for _, partName in ipairs(bodyParts) do
            local part = character:FindFirstChild(partName)
            if part then
                local highlight = Instance.new("Highlight")
                highlight.Name = "ESP_Skeleton_" .. partName .. "_" .. targetPlayer.Name
                highlight.FillColor = Color3.fromRGB(255, 165, 0)
                highlight.FillTransparency = 0.7
                highlight.OutlineColor = Color3.fromRGB(255, 165, 0)
                highlight.OutlineTransparency = 0
                highlight.Adornee = part
                highlight.Parent = character
                table.insert(espData.lines, highlight)
            end
        end
    end
end

function updateESP()
    clearESP()
    
    if not (nameEspEnabled or boxEspEnabled or skeletonEspEnabled) then
        return
    end
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            createESPForPlayer(otherPlayer)
        end
    end
    
    espConnections.update = RunService.RenderStepped:Connect(function()
        for targetPlayer, espData in pairs(espObjects) do
            local character = espData.character
            if character and character:IsDescendantOf(workspace) then
                local head = character:FindFirstChild("Head")
                local humanoid = character:FindFirstChild("Humanoid")
                
                if head and humanoid and humanoid.Health > 0 then
                    local camera = workspace.CurrentCamera
                    local headScreenPos, headVisible = camera:WorldToViewportPoint(head.Position)
                    
                    if nameEspEnabled then
                        for _, label in ipairs(espData.labels) do
                            if label:IsA("TextLabel") then
                                label.Visible = true
                                label.Position = UDim2.new(0, headScreenPos.X, 0, headScreenPos.Y - 50)
                            end
                        end
                    end
                    
                    if boxEspEnabled then
                        for _, box in ipairs(espData.boxes) do
                            if box:IsA("Frame") then
                                box.Visible = true
                                box.Size = UDim2.new(0, 100, 0, 200)
                                box.Position = UDim2.new(0, headScreenPos.X - 50, 0, headScreenPos.Y - 100)
                            end
                        end
                    end
                else
                    for _, obj in ipairs(espData.labels) do
                        obj.Visible = false
                    end
                    for _, obj in ipairs(espData.boxes) do
                        obj.Visible = false
                    end
                end
            else
                for _, obj in ipairs(espData.labels) do
                    obj.Visible = false
                end
                for _, obj in ipairs(espData.boxes) do
                    obj.Visible = false
                end
            end
        end
    end)
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            espConnections[otherPlayer] = otherPlayer.CharacterAdded:Connect(function(character)
                task.wait(1)
                if nameEspEnabled or boxEspEnabled or skeletonEspEnabled then
                    createESPForPlayer(otherPlayer)
                end
            end)
        end
    end
end

function clearESP()
    if espConnections.update then
        espConnections.update:Disconnect()
        espConnections.update = nil
    end
    
    for player, connection in pairs(espConnections) do
        if player ~= "update" then
            connection:Disconnect()
        end
    end
    espConnections = {}
    
    for _, espData in pairs(espObjects) do
        for _, label in ipairs(espData.labels) do
            label:Destroy()
        end
        for _, box in ipairs(espData.boxes) do
            box:Destroy()
        end
        for _, line in ipairs(espData.lines) do
            line:Destroy()
        end
    end
    espObjects = {}
end

function startTriggerBot()
    if triggerBotConnection then
        triggerBotConnection:Disconnect()
    end
    
    triggerBotConnection = RunService.RenderStepped:Connect(function()
        if not triggerBotEnabled then
            return
        end
        
        local currentTime = tick()
        if currentTime - lastTriggerTime < triggerDelay then
            return
        end
        
        local target = getTarget()
        if target then
            VirtualInputManager:SendMouseButtonEvent(mouse.X, mouse.Y, 0, true, game, 1)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(mouse.X, mouse.Y, 0, false, game, 1)
            lastTriggerTime = currentTime
        end
    end)
end

function stopTriggerBot()
    if triggerBotConnection then
        triggerBotConnection:Disconnect()
        triggerBotConnection = nil
    end
end

function getTarget()
    local character = player.Character
    if not character then 
        return nil 
    end
    
    local camera = workspace.CurrentCamera
    local nearestTarget = nil
    local nearestDistance = math.huge
    local characterPosition = character:GetPivot().Position
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character then
            local targetChar = otherPlayer.Character
            local humanoid = targetChar:FindFirstChild("Humanoid")
            local head = targetChar:FindFirstChild("Head")
            local rootPart = targetChar:FindFirstChild("HumanoidRootPart")
            
            if humanoid and humanoid.Health > 0 and head and rootPart then
                local targetPosition = rootPart.Position
                local distance = (targetPosition - characterPosition).Magnitude
                
                local headScreenPos, headVisible = camera:WorldToScreenPoint(head.Position)
                
                if headVisible then
                    local heightDifference = math.abs(targetPosition.Y - characterPosition.Y)
                    
                    if heightDifference < 10 then
                        if distance < nearestDistance then
                            local ray = Ray.new(camera.CFrame.Position, (head.Position - camera.CFrame.Position).Unit * 1000)
                            local hit, position = workspace:FindPartOnRay(ray, character)
                            
                            if hit and hit:IsDescendantOf(targetChar) then
                                nearestTarget = targetChar
                                nearestDistance = distance
                            end
                        end
                    end
                end
            end
        end
    end
    
    return nearestTarget
end

function startAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
    end
    
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not aimbotEnabled then
            return
        end
        
        local newTarget = getTarget()
        
        if newTarget then
            currentTarget = newTarget
            local camera = workspace.CurrentCamera
            local targetAimPart = currentTarget:FindFirstChild(aimPart)
            
            if targetAimPart then
                local currentCFrame = camera.CFrame
                local targetPosition = targetAimPart.Position
                local newCFrame = currentCFrame:Lerp(CFrame.lookAt(currentCFrame.Position, targetPosition), smoothness)
                camera.CFrame = newCFrame
            end
        else
            currentTarget = nil
        end
    end)
end

function stopAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
    currentTarget = nil
end

