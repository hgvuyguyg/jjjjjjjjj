    fovLabel.Position = UDim2.new(0, 10, 0, layoutY)
    fovLabel.BackgroundTransparency = 1
    fovLabel.Text = "瞄准范围: " .. fovCircle
    fovLabel.TextColor3 = Color3.new(1, 1, 1)
    fovLabel.Font = Enum.Font.Gotham
    fovLabel.TextSize = 14
    fovLabel.TextXAlignment = Enum.TextXAlignment.Left
    fovLabel.Parent = contentFrame
    
    layoutY = layoutY + 30
    
    local sliderFov = Instance.new("Frame")
    sliderFov.Size = UDim2.new(1, -20, 0, 12)
    sliderFov.Position = UDim2.new(0, 10, 0, layoutY)
    sliderFov.BackgroundColor3 = Color3.new(1, 1, 1)
    sliderFov.BackgroundTransparency = 0.7
    sliderFov.Active = true
    sliderFov.Selectable = true
    Instance.new("UICorner", sliderFov).CornerRadius = UDim.new(1, 0)
    sliderFov.Parent = contentFrame

    local fillFov = Instance.new("Frame")
    fillFov.Size = UDim2.new((fovCircle - 10) / 190, 0, 1, 0)
    fillFov.BackgroundColor3 = Color3.fromRGB(76, 175, 80)
    fillFov.BorderSizePixel = 0
    Instance.new("UICorner", fillFov).CornerRadius = UDim.new(1, 0)
    fillFov.Parent = sliderFov

    local draggingFov = false
    local function updateFov(x)
        local sliderAbsolutePos = sliderFov.AbsolutePosition
        local sliderAbsoluteSize = sliderFov.AbsoluteSize
        local rel = math.clamp((x - sliderAbsolutePos.X) / sliderAbsoluteSize.X, 0, 1)
        fillFov.Size = UDim2.new(rel, 0, 1, 0)
        local newFov = math.floor(rel * 190 + 10)
        fovCircle = newFov
        fovLabel.Text = "瞄准范围: " .. tostring(newFov)
    end

    sliderFov.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            draggingFov = true
            updateFov(inp.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            draggingFov = false
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if draggingFov and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
            updateFov(inp.Position.X)
        end
    end)
    
    layoutY = layoutY + 30
    
    local smoothLabel = Instance.new("TextLabel")
    smoothLabel.Size = UDim2.new(1, -20, 0, 25)
    smoothLabel.Position = UDim2.new(0, 10, 0, layoutY)
    smoothLabel.BackgroundTransparency = 1
    smoothLabel.Text = "平滑度: " .. string.format("%.2f", smoothness)
    smoothLabel.TextColor3 = Color3.new(1, 1, 1)
    smoothLabel.Font = Enum.Font.Gotham
    smoothLabel.TextSize = 14
    smoothLabel.TextXAlignment = Enum.TextXAlignment.Left
    smoothLabel.Parent = contentFrame
    
    layoutY = layoutY + 30
    
    local sliderSmooth = Instance.new("Frame")
    sliderSmooth.Size = UDim2.new(1, -20, 0, 12)
    sliderSmooth.Position = UDim2.new(0, 10, 0, layoutY)
    sliderSmooth.BackgroundColor3 = Color3.new(1, 1, 1)
